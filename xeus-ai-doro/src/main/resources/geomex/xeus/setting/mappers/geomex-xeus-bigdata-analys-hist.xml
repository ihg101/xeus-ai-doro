<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="geomex.xeus.bigdata.service.BigDataAnalyHistMapper">

   <select id="getCount" parameterType="HashMap" resultType="int">
        SELECT count(*)  FROM xeus.bigdata_analy_hist
        <where>
            <if test="mgrSeq != null and mgrSeq != ''">
                AND mgr_seq = #{mgrSeq}::numeric
            </if>
           <if test="analyMgrSeq != null and analyMgrSeq != ''">
                AND analy_mgr_seq = #{analyMgrSeq}::numeric
            </if>
            <if test="analyDat != null and analyDat != ''">
                AND analy_dat LIKE '%'||#{analyDat}||'%'
            </if>
            <if test="finishDat != null and finishDat != ''">
                AND finish_dat = #{finishDat}
            </if>
            <if test="analyState != null and analyState != ''">
                AND analy_state = #{analyState}
            </if>
            <if test="resultTblNm != null and resultTblNm != ''">
                AND result_tbl_nm = #{resultTblNm}
            </if>
        </where>
    </select>

    <select id="getList" parameterType="HashMap" resultType="BigDataAnalyHistVo">
        SELECT mgr_seq, analy_mgr_seq, analy_dat, finish_dat, analy_state,result_tbl_nm,error_msg
        FROM xeus.bigdata_analy_hist
        <where>
            <if test="mgrSeq != null and mgrSeq != ''">
                AND mgr_seq = #{mgrSeq}::numeric
            </if>
            <if test="analyMgrSeq != null and analyMgrSeq != ''">
                AND analy_mgr_seq = #{analyMgrSeq}::numeric
            </if>
            <if test="analyDat != null and analyDat != ''">
                AND analy_dat = #{analyDat}
            </if>
            <if test="analyStartDat != null and analyStartDat != ''">
                AND analy_dat >= #{analyStartDat}
            </if>
            <if test="finishDat != null and finishDat != ''">
                AND finish_dat = #{finishDat}
            </if>
            <if test="analyState != null and analyState != ''">
                AND analy_state = #{analyState}
            </if>
            <if test="resultTblNm != null and resultTblNm != ''">
                AND result_tbl_nm = #{resultTblNm}
            </if>
            <if test="errorMsg != null and errorMsg != ''">
                AND error_msg = #{errorMsg}
            </if>
        </where>
        <trim prefix="ORDER BY">
            <if test="sortCol != null and sortCol != '' and sortTyp != null and sortTyp != ''">
                ${sortCol} ${sortTyp}
            </if>
            <if test="sortCol == null and sortTyp == null">
                mgr_seq asc
            </if>
        </trim>
        <if test="limit != null and limit != '' and offset != null and offset != ''">
            LIMIT ${limit} OFFSET ${offset}
        </if>
    </select>

    <select id="getItem" parameterType="HashMap" resultType="BigDataAnalyHistVo">
        SELECT mgr_seq, analy_mgr_seq, analy_dat, finish_dat, analy_state,result_tbl_nm,error_msg
        FROM xeus.bigdata_analy_hist
        <where>
            <if test="mgrSeq != null and mgrSeq != ''">
                AND mgr_seq = #{mgrSeq}::numeric
            </if>
            <if test="analyMgrSeq != null and analyMgrSeq != ''">
                AND analy_mgr_seq = #{analyMgrSeq}::numeric
            </if>
            <if test="analyDat != null and analyDat != ''">
                AND analy_dat = #{analyDat}
            </if>
            <if test="finishDat != null and finishDat != ''">
                AND finish_dat = #{finishDat}
            </if>
            <if test="analyState != null and analyState != ''">
                AND analy_state = #{analyState}
            </if>
            <if test="resultTblNm != null and resultTblNm != ''">
                AND result_tbl_nm = #{resultTblNm}
            </if>
            <if test="errorMsg != null and errorMsg != ''">
                AND error_msg = #{errorMsg}
            </if>
        </where>
    </select>


    <delete id="del" parameterType="HashMap">
        DELETE FROM xeus.bigdata_analy_hist
        <where>
          <if test="mgrSeq != null and mgrSeq != ''">
                AND mgr_seq = #{mgrSeq}::numeric
          </if>
          <if test="analyMgrSeq != null and analyMgrSeq != ''">
                AND analy_mgr_seq = #{analyMgrSeq}::numeric
          </if>
        </where>
    </delete>


    <insert id="add" parameterType="BigDataAnalyHistVo">
        INSERT INTO xeus.bigdata_analy_hist(
        analy_mgr_seq, analy_dat, finish_dat, analy_state,result_tbl_nm,error_msg
        )
        VALUES (
        #{analyMgrSeq}::numeric, #{analyDat}, #{finishDat}, #{analyState}, #{resultTblNm},#{errorMsg}
        );

        <selectKey keyProperty="mgrSeq" resultType="string" order="AFTER">
            SELECT mgr_seq FROM xeus.bigdata_analy_hist
            WHERE analy_mgr_seq = #{analyMgrSeq}::numeric AND result_tbl_nm = #{resultTblNm}
        </selectKey>
    </insert>


    <update id="edit" parameterType="BigDataAnalyzeVo">
        UPDATE xeus.bigdata_analy_hist SET
        mgr_seq = #{mgrSeq}::numeric

        <if test="analyMgrSeq != null and analyMgrSeq != ''">
            , analy_mgr_seq = #{analyMgrSeq}::numeric
        </if>
        <if test="analyDat != null and analyDat != ''">
            , analy_dat = #{analyDat}
        </if>
        <if test="finishDat != null and finishDat != ''">
            , finish_dat = #{finishDat}
        </if>
        <if test="analyState != null and analyState != ''">
            , analy_state = #{analyState}
        </if>
        <if test="resultTblNm != null and resultTblNm != ''">
            , result_tbl_nm = #{resultTblNm}
        </if>
        <if test="errorMsg != null and errorMsg != ''">
            , error_msg = #{errorMsg}
        </if>
        WHERE mgr_seq = #{mgrSeq}::numeric
    </update>

