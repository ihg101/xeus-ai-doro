<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="geomex.xeus.tvius.service.CrmsHeatMapper">

    <select id="getCntOfCrimeTyp" parameterType="HashMap" resultType="CrmsHeatVo">
        SELECT crime_typ, count(crime_typ) AS cnt
        FROM xeus.v_asset_cctv_heat

        <where>
            <if test="crimeTyp != null and crimeTyp != ''">
                AND crime_typ IN (${crimeTyp})
            </if>

            <if test="reqGbn != null and reqGbn != ''">
                AND req_gbn IN (${reqGbn})
            </if>

            <if test="startDat!= null and startDat != ''">
                AND reqst_dat <![CDATA[ >= ]]> #{startDat}
            </if>

            <if test="endDat != null and endDat != ''">
                AND reqst_dat <![CDATA[ <= ]]> #{endDat}
            </if>

        </where>

        GROUP BY crime_typ
    </select>

</mapper>