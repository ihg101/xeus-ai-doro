<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="org.apache.commons.lang3.StringUtils"%>
<%@ page import="java.text.SimpleDateFormat"%>
<%@ page import="java.util.Calendar"%>
<%@ page import="java.util.Date"%>
<%
String token = (String) request.getAttribute("token");
String validTokenTime = (String) request.getAttribute("validTokenTime");
String expireTokenTime = (String) request.getAttribute("expireTokenTime");

SimpleDateFormat formatter = new SimpleDateFormat("MM월 dd일 HH시 mm분 ss초");
SimpleDateFormat sdf = new SimpleDateFormat("yyyyMMddHHmmss");
Date tokenTime = sdf.parse(expireTokenTime);

Calendar cal = Calendar.getInstance();
cal.setTime(tokenTime);

String ttsToken = " ";
for(int i=0; i<token.length(); i++){
	ttsToken += token.substring(i, (i + 1)) + " ";
}
%>
<script type="text/javascript">
	(function(){

		/*
		 * 해당 url을 argos full url로 변환한다
		 */
		var changeUrlByCctv = function(url){
			//내부망일 때
			if(location.host.contains("101.102.104.113")){
				url = "http://101.102.104.113:9090/xeus"+url;
			}
			//로컬일 때
			else if(location.host.contains("127.0.0.1")){

				url = "http://"+location.host+"/xeus"+url;
			}
			//외부망일때
			else{
				url = "http://cctv.seocho.go.kr/xeus"+url;
			}

			return url;
		}

		$("#reloadToken").click(function(){
			$("#btn-tvius-tablet-password-view").click();
		});

		$("#createToken").click(function(){

			var _URL = changeUrlByCctv("/tvius/mobile/setTokenRegeneration.json");
			if(confirm("인증 암호를 신규 생성 하시겠습니까?")){
				_common.callAjax(_URL, {}, function(json){
					if(json.result) $("#btn-tvius-tablet-password-view").click();
				});
			}
		});

		$("#speechToken").click(function(){
			if(("SpeechSynthesisUtterance" in window) && ("speechSynthesis" in window)){
				var msg = new SpeechSynthesisUtterance();
				var voices = speechSynthesis.getVoices();
				//msg.voice = voices[13];
				msg.voice = voices[1];
				msg.voiceURI = "native";
				msg.volume = 1;
				msg.pitch = 1;
				msg.rate = 0.5;
				msg.text = $("#tabletPassword").attr("token");

				speechSynthesis.speak(msg);
			}
		});



	})();

</script>

<div class="contentWrapper customScroll">
	<div style="position: absolute; top: calc(50% - 220px); left: calc(50% - 170px); font-size: 35px;">
		<img style="width: 300px; background: #0078d4; border-radius: 50%; padding: 20px; transform: rotate(-90deg);" src="data:image/png;base64,">
		<p id="tabletPassword" class="tCenter" token="<%= ttsToken %>" style="position: absolute; top: 125px; left: 0px; width: 100%;"><%= token %><br><img id="speechToken" style="margin-top: 10px; cursor: pointer; width: 30px; background: #0078d4; border-radius: 50%; padding: 5px;" src="data:image/png;base64,"></p>
		<p style="text-align: center; font-size: 17px; margin-top: 10px;"><%= formatter.format(cal.getTime()) %> 까지 유효<br>(5분 주기 갱신)</p>
		<div style="text-align: center; margin-top: 10px;">
			<button id="reloadToken" class="btn_style2" style="padding: 10px;">암호 새로 고침</button>
			<button id="createToken" class="btn_style2" style="padding: 10px;">암호 신규 생성</button>
		</div>

	</div>
</div>