<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="geomex.xeus.util.code.DateUtil"%>
<!DOCTYPE html>
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0"/>
<link rel="shortcut icon" href="../res/img/geomex.ico">
<link rel="stylesheet" type="text/css" href="../common/ui-1.12.1/themes/ui-darkness/jquery-ui.css?v=<%= DateUtil.getStrMilSec() %>">
<link rel="stylesheet" type="text/css" href="../res/css/xeus.login.css?v=<%= DateUtil.getStrMilSec() %>">
<link rel="stylesheet" type="text/css" href="../res/css/xeus.layout.css?v=<%= DateUtil.getStrMilSec() %>">
<title>지원하지 않는 브라우저</title>
<script type="text/javascript" src="../common/jquery-3.2.0.min.js?v=<%= DateUtil.getStrMilSec() %>"></script>
<script type="text/javascript" src="../common/ui-1.12.1/jquery-ui.min.js?v=<%= DateUtil.getStrMilSec() %>"></script>
<style type="text/css">
.login_container { width: 900px; text-align: center; top: 55%; left: calc(50% - 450px); }
.main_title { font-size: 3.5em; line-height: 80px; }
#downBtn { color: white; font-weight: bold; font-size: 2em; border: 1px solid white; border-radius: 10px; padding: 10px 30px; transition: 0.7s; }
#downBtn:hover { background: white; color: black; }
</style>
<script>
$(document).ready(function(){
	var bgTime = 0;

	setInterval(bgTime2, 5000);

	function bgTime2(){
		bgTime++;
		if(bgTime>1){
			bgTime = 0;
		}
		bgChange(bgTime);
	}

	function bgChange(time){
		$('body').css({'background-image': 'url(../res/img/bg'+ time +'.jpg)'});
	}

	$("#downBtn").click(function(){
		window.open("../res/file/ChromeStandaloneSetup64.exe");
	});
});
</script>
</head>
<body style="background-image: url('../res/img/bg0.jpg');">

<div id="login_wrap">
	<div class="login_container log">
		<img style="margin: 50px;" src="data:image/png;base64,">
		<!-- <img width="128px" height="128px" src="data:image/png;base64,"> -->
		<h1 class="main_title">스마트시티 통합플랫폼은<br>Google Chrome 브라우저를 지원합니다.</h1>
		<button id="downBtn">크롬 브라우저 다운로드</button>
	</div>
</div>

</body>
</html>